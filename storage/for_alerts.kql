["weather-table"]
| where alerts != '[]'
| extend AlertValue = tostring(alerts)
| summarize LastTriggered = max(EventProcessedUtcTime) by AlertValue
| join kind=leftanti (
    ['weather-table']
    | where alerts != '[]'
    | extend AlertValue = tostring(alerts)
    | summarize LastTriggered = max(EventProcessedUtcTime) by AlertValue
    | where LastTriggered < ago(1m)
) on AlertValue